APP_NAME=bytecode-api
APP_PORT=8080
APP_ENV=development

SWAGGER_ENABLED=true
SWAGGER_USERNAME=
SWAGGER_PASSWORD=

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=bytecode_api
DB_SSLMODE=disable

JWT_SECRET=your-super-secret-key
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_HOURS=168

REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL_MINUTES=5

STORAGE_PROVIDER=local
STORAGE_DEFAULT_BUCKET=uploads
STORAGE_BUCKETS=uploads,images
STORAGE_LOCAL_PATH=storage
STORAGE_BASE_URL=/storage

MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# Set to redis, minio, or both like redis,minio if you want docker compose to start them too
COMPOSE_PROFILES=

LOG_LEVEL=debug
